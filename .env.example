# Solo Builder OS — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Required: Your OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# Optional: Use Anthropic Claude instead (requires minor code change — see core-engine/README.md)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Set a custom model (default: gpt-4o)
# SOLO_OS_MODEL=gpt-4o-mini
